{
  "entities": {
    "User": {
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Phone number acts as UID" },
        "displayName": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "photoURL": { "type": "string" },
        "publicKey": { "type": "string", "description": "RSA Public Key for E2EE" },
        "lockedChats": { "type": "array", "items": { "type": "string" }, "description": "Array of user/group IDs that are locked" },
        "password": { "type": "string", "description": "Optional account password" }
      },
      "required": ["uid", "displayName", "phoneNumber", "publicKey"]
    },
    "Message": {
      "type": "object",
      "properties": {
        "senderId": { "type": "string" },
        "receiverId": { "type": "string" },
        "ciphertext": { "type": "string" },
        "iv": { "type": "string" },
        "encKeySender": { "type": "string" },
        "encKeyReceiver": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "type": { "type": "string", "enum": ["text", "audio", "image", "file"] },
        "fileName": { "type": "string" },
        "fileSize": { "type": "number" }
      },
      "required": ["senderId", "receiverId", "ciphertext", "iv", "encKeySender", "encKeyReceiver", "timestamp"]
    },
    "Status": {
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "type": { "type": "string", "enum": ["text", "image"] },
        "content": { "type": "string", "description": "Base64 image or text content" },
        "timestamp": { "type": "string", "format": "date-time" },
        "expiresAt": { "type": "number", "description": "Unix timestamp in milliseconds for 24h expiration" },
        "likes": { "type": "array", "items": { "type": "string" }, "description": "List of user UIDs who liked the status" }
      },
      "required": ["userId", "type", "content", "timestamp", "expiresAt"]
    },
    "Group": {
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "members": { "type": "array", "items": { "type": "string" } },
        "createdBy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "photoURL": { "type": "string" }
      },
      "required": ["name", "members", "createdBy", "createdAt"]
    },
    "Call": {
      "type": "object",
      "properties": {
        "callerId": { "type": "string" },
        "receiverId": { "type": "string" },
        "type": { "type": "string", "enum": ["audio", "video"] },
        "status": { "type": "string", "enum": ["ringing", "accepted", "rejected", "ended"] },
        "offer": { "type": "object" },
        "answer": { "type": "object" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["callerId", "receiverId", "type", "status", "timestamp"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "User profiles and their public keys"
    },
    "messages/{messageId}": {
      "schema": "Message",
      "description": "End-to-End Encrypted messages between users"
    },
    "statuses/{statusId}": {
      "schema": "Status",
      "description": "24-hour disappearing statuses (images/text)"
    },
    "groups/{groupId}": {
      "schema": "Group",
      "description": "Group chat rooms"
    },
    "calls/{callId}": {
      "schema": "Call",
      "description": "Voice and video call signaling"
    },
    "calls/{callId}/callerCandidates/{candidateId}": {
      "schema": "object",
      "description": "ICE candidates from the caller"
    },
    "calls/{callId}/receiverCandidates/{candidateId}": {
      "schema": "object",
      "description": "ICE candidates from the receiver"
    }
  }
}
